#!/usr/bin/env bash
# Posts a message to one or more Discord webhooks for Gentoo QA reporting.
# Usage: ./say "your message"   (or: ./say < file)
#
# Webhook URLs are NOT hard-coded (this repo is public; bots scrape Discord
# webhooks). They are read from:
#   - $SAY_WEBHOOK (space/newline separated), and/or
#   - a local gitignored `.webhook` file next to this script (or one dir up),
#     one URL per line; blank lines and lines starting with '#' are ignored.
# All discovered webhooks receive the message.
set -u

# collect webhook URLs into an array
WEBHOOKS=()
[ -n "${SAY_WEBHOOK:-}" ] && for w in $SAY_WEBHOOK; do WEBHOOKS+=("$w"); done
d="$(cd "$(dirname "$0")" && pwd)"
for f in "$d/.webhook" "$d/../.webhook" "./.webhook"; do
  if [ -f "$f" ]; then
    while IFS= read -r line; do
      line="${line%%$'\r'}"
      case "$line" in ''|\#*) continue ;; esac
      WEBHOOKS+=("$line")
    done < "$f"
    break
  fi
done

if [ "${#WEBHOOKS[@]}" -eq 0 ]; then
  echo "[say] no webhook configured (set SAY_WEBHOOK or create .webhook)" >&2
  exit 1
fi

msg="${*:-}"
[ -z "$msg" ] && msg="$(cat)"
# Discord content cap is 2000 chars; trim defensively.
[ "${#msg}" -gt 1900 ] && msg="${msg:0:1900}...(truncated)"

payload="$(jq -Rn --arg c "$msg" '{content:$c}')"
ok=0; fail=0
for w in "${WEBHOOKS[@]}"; do
  if curl -sS -H "Content-Type: application/json" -d "$payload" "$w" >/dev/null; then
    ok=$((ok+1))
  else
    fail=$((fail+1)); echo "[say] FAILED -> ${w%%/webhooks/*}/.../$(echo "$w" | grep -oE '[0-9]{15,}' | head -1)" >&2
  fi
done
echo "[say] sent to $ok webhook(s)${fail:+, $fail failed} (${#msg} chars)"
